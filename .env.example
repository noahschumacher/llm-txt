# Application
APP_ENV=local  # local | dev | prod
APP_PORT=8080

# LLM (required for enhanced mode)
LLM_PROVIDER=anthropic  # anthropic | openai
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5  # claude-haiku-4-5 | gpt-4o-mini

# Crawler
CRAWL_MAX_PAGES=50
CRAWL_MAX_DEPTH=3
CRAWL_DELAY_MS=500

# LLM concurrency
LLM_CONCURRENCY=5
